{% extends 'base.html' %}
{% load static %}

{% block title %}Estadísticas - TickPro{% endblock %}

{% block content %}
<!-- Encabezado de página -->
<div class="page-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center">
            <h1>
                <i class="fas fa-chart-bar me-3"></i> ESTADÍSTICAS
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{% url 'pagina_principal' %}">Inicio</a></li>
                    <li class="breadcrumb-item"><a href="{% url 'configuracion' %}">Configuración</a></li>
                    <li class="breadcrumb-item active">Estadísticas</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<div class="container">
    <!-- Tarjetas de resumen -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Total Tickets</h6>
                            <h2 class="mb-0">{{ total_tikects|default:"0" }}</h2>
                        </div>
                        <i class="fas fa-ticket-alt fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Tickets Abiertos</h6>
                            <h2 class="mb-0">{{ tikects_abiertos|default:"0" }}</h2>
                            <small>{{ porcentaje_abiertos|floatformat:1 }}%</small>
                        </div>
                        <i class="fas fa-folder-open fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Tickets Cerrados</h6>
                            <h2 class="mb-0">{{ tikects_cerrados|default:"0" }}</h2>
                            <small>{{ porcentaje_cerrados|floatformat:1 }}%</small>
                        </div>
                        <i class="fas fa-check-circle fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Tiempo Promedio</h6>
                            <h2 class="mb-0">{{ tiempo_promedio|default:"0" }}</h2>
                            <small>horas</small>
                        </div>
                        <i class="fas fa-clock fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Gráficos -->
    <div class="row">
        <!-- Gráfico de torta: Estado de tickets -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-pie me-2"></i> Estado de Tickets</h5>
                </div>
                <div class="card-body">
                    <canvas id="tikectsStatusChart" height="200"></canvas>
                    <div class="mt-3 text-center">
                        <p class="mb-1"><strong>Total:</strong> {{ total_tikects }}</p>
                        <p class="mb-1"><span class="badge bg-success">Abiertos: {{ tikects_abiertos }}</span></p>
                        <p class="mb-1"><span class="badge bg-danger">Cerrados: {{ tikects_cerrados }}</span></p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Gráfico de barras: Tickets por servicio -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-bar me-2"></i> Tickets por Servicio</h5>
                </div>
                <div class="card-body">
                    <canvas id="tikectsServiceChart" height="200"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Tickets por día -->
        <div class="col-md-12 mb-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-line me-2"></i> Tickets Cerrados por Día</h5>
                </div>
                <div class="card-body">
                    <canvas id="tikectsPorDiaCerradosChart" height="100"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Tickets por mes -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-calendar-alt me-2"></i> Tickets por Mes</h5>
                </div>
                <div class="card-body">
                    <canvas id="tikectsPorMesCerradosChart" height="200"></canvas>
                </div>
            </div>
        </div>

        <!-- Tickets por semana -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-calendar-week me-2"></i> Tickets por Semana</h5>
                </div>
                <div class="card-body">
                    <canvas id="tikectsPorSemanaCerradosChart" height="200"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Tickets cerrados por agente -->
    <div class="row">
        <div class="col-md-12 mb-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-user-tie me-2"></i> Tickets Cerrados por Agente</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Agente</th>
                                    <th>Username</th>
                                    <th>Tickets Cerrados</th>
                                    <th>% del Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for agente in tikects_por_agente %}
                                <tr>
                                    <td>{{ forloop.counter }}</td>
                                    <td>
                                        {{ agente.cerrado_por_agente__agente__nombre }} 
                                        {{ agente.cerrado_por_agente__agente__apellido }}
                                    </td>
                                    <td>{{ agente.cerrado_por_agente__username }}</td>
                                    <td>
                                        <span class="badge bg-primary">{{ agente.count }}</span>
                                    </td>
                                    <td>
                                        {% widthratio agente.count tikects_cerrados 100 %}%
                                    </td>
                                </tr>
                                {% empty %}
                                <tr>
                                    <td colspan="5" class="text-center">No hay datos disponibles</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Botones de exportación -->
    <div class="row mb-5">
        <div class="col-md-12 text-center">
            <button type="button" class="btn btn-success me-2" data-bs-toggle="modal" data-bs-target="#exportExcelModal">
                <i class="fas fa-file-excel me-2"></i> Exportar a Excel
            </button>
            <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#exportPdfModal">
                <i class="fas fa-file-pdf me-2"></i> Exportar a PDF
            </button>
        </div>
    </div>
</div>

<!-- Modal para exportar a Excel -->
<div class="modal fade" id="exportExcelModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">
                    <i class="fas fa-file-excel me-2"></i> Exportar a Excel
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="GET" action="{% url 'exportar_tikects_excel' %}">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="servicio_excel" class="form-label">Seleccionar Servicio:</label>
                        <select name="servicio" id="servicio_excel" class="form-select">
                            <option value="Todo">Todos los servicios</option>
                            {% for servicio in servicios %}
                                <option value="{{ servicio.servicio__nombre }}">
                                    {{ servicio.servicio__nombre }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-download me-2"></i> Exportar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal para exportar a PDF -->
<div class="modal fade" id="exportPdfModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fas fa-file-pdf me-2"></i> Exportar a PDF
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="GET" action="{% url 'exportar_tikects_pdf' %}">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="servicio_pdf" class="form-label">Seleccionar Servicio:</label>
                        <select name="servicio" id="servicio_pdf" class="form-select">
                            <option value="Todo">Todos los servicios</option>
                            {% for servicio in servicios %}
                                <option value="{{ servicio.servicio__nombre }}">
                                    {{ servicio.servicio__nombre }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-download me-2"></i> Exportar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Scripts de Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Gráfico de torta: Estado de tickets
    const tikectsStatusData = {
        labels: ['Abiertos', 'Cerrados'],
        datasets: [{
            data: [{{ tikects_abiertos }}, {{ tikects_cerrados }}],
            backgroundColor: ['#28a745', '#dc3545'],
            borderWidth: 0
        }]
    };

    const tikectsStatusConfig = {
        type: 'pie',
        data: tikectsStatusData,
        options: {
            responsive: true,
            plugins: {
                legend: {
                    position: 'bottom',
                }
            }
        }
    };

    new Chart(
        document.getElementById('tikectsStatusChart'),
        tikectsStatusConfig
    );

    // Gráfico de barras: Tickets por servicio
    const tikectsServiceData = {
        labels: [{% for servicio in servicios %}'{{ servicio.servicio__nombre }}'{% if not forloop.last %}, {% endif %}{% endfor %}],
        datasets: [{
            label: 'Cantidad de Tickets',
            data: [{% for servicio in servicios %}{{ servicio.count }}{% if not forloop.last %}, {% endif %}{% endfor %}],
            backgroundColor: '#17a2b8',
            borderColor: '#138496',
            borderWidth: 1
        }]
    };

    const tikectsServiceConfig = {
        type: 'bar',
        data: tikectsServiceData,
        options: {
            responsive: true,
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        stepSize: 1
                    }
                }
            }
        }
    };

    new Chart(
        document.getElementById('tikectsServiceChart'),
        tikectsServiceConfig
    );

    // Gráfico de línea: Tickets cerrados por día
    const tikectsPorDiaCerradosData = {
        labels: [{% for item in tikects_por_dia_cerrados %}'{{ item.fecha_cierre__date|date:"d/m/Y" }}'{% if not forloop.last %}, {% endif %}{% endfor %}],
        datasets: [{
            label: 'Tickets Cerrados',
            data: [{% for item in tikects_por_dia_cerrados %}{{ item.count }}{% if not forloop.last %}, {% endif %}{% endfor %}],
            borderColor: '#dc3545',
            backgroundColor: 'rgba(220, 53, 69, 0.1)',
            tension: 0.4,
            fill: true
        }]
    };

    const tikectsPorDiaCerradosConfig = {
        type: 'line',
        data: tikectsPorDiaCerradosData,
        options: {
            responsive: true,
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        stepSize: 1
                    }
                }
            }
        }
    };

    new Chart(
        document.getElementById('tikectsPorDiaCerradosChart'),
        tikectsPorDiaCerradosConfig
    );

    // Gráfico de barras: Tickets cerrados por mes
    const tikectsPorMesCerradosData = {
        labels: [{% for item in tikects_por_mes_cerrados %}'{{ item.month|date:"M Y" }}'{% if not forloop.last %}, {% endif %}{% endfor %}],
        datasets: [{
            label: 'Tickets Cerrados',
            data: [{% for item in tikects_por_mes_cerrados %}{{ item.count }}{% if not forloop.last %}, {% endif %}{% endfor %}],
            backgroundColor: '#007bff',
            borderColor: '#0056b3',
            borderWidth: 1
        }]
    };

    const tikectsPorMesCerradosConfig = {
        type: 'bar',
        data: tikectsPorMesCerradosData,
        options: {
            responsive: true,
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        stepSize: 1
                    }
                }
            }
        }
    };

    new Chart(
        document.getElementById('tikectsPorMesCerradosChart'),
        tikectsPorMesCerradosConfig
    );

    // Gráfico de línea: Tickets cerrados por semana
    const tikectsPorSemanaCerradosData = {
        labels: [{% for item in tikects_por_semana_cerrados %}'Sem {{ item.week|date:"W Y" }}'{% if not forloop.last %}, {% endif %}{% endfor %}],
        datasets: [{
            label: 'Tickets Cerrados',
            data: [{% for item in tikects_por_semana_cerrados %}{{ item.count }}{% if not forloop.last %}, {% endif %}{% endfor %}],
            borderColor: '#ffc107',
            backgroundColor: 'rgba(255, 193, 7, 0.1)',
            tension: 0.4,
            fill: true
        }]
    };

    const tikectsPorSemanaCerradosConfig = {
        type: 'line',
        data: tikectsPorSemanaCerradosData,
        options: {
            responsive: true,
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        stepSize: 1
                    }
                }
            }
        }
    };

    new Chart(
        document.getElementById('tikectsPorSemanaCerradosChart'),
        tikectsPorSemanaCerradosConfig
    );
</script>
{% endblock %}